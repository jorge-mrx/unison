APP_ENV=development

# SQLite local. In deploy → postgresql://...
DATABASE_URL=file:./local.db

# NextAuth v5 — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Upstash Redis (guest rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
